# ── Django ──────────────────────────────────────────────────────────────
SECRET_KEY=sua-secret-key-longa-e-aleatoria-aqui
DEBUG=True
ALLOWED_HOSTS=*

# ── Banco de dados ───────────────────────────────────────────────────────
DATABASE_URL=sqlite:///db.sqlite3
# Em produção: DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── IA (Groq - grátis) ──────────────────────────────────────────────────
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ── MercadoPago ──────────────────────────────────────────────────────────
# 1. Acesse: https://www.mercadopago.com.br/developers/panel
# 2. Crie um app e copie as chaves de TESTE (começam com TEST-)
# 3. Para produção, use as chaves de produção
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxx-sua-chave-aqui
MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxxxxxx-sua-chave-publica

# ── Email (Gmail) ────────────────────────────────────────────────────────
# Para usar Gmail:
# 1. Ative verificação em 2 etapas na sua conta Google
# 2. Acesse: myaccount.google.com/apppasswords
# 3. Crie uma senha de app e cole abaixo
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=seuemail@gmail.com
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
DEFAULT_FROM_EMAIL=OrderUP <seuemail@gmail.com>

# Para desenvolvimento (printa emails no terminal, sem precisar de Gmail):
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ── URL do site ──────────────────────────────────────────────────────────
# Em desenvolvimento:
SITE_URL=http://localhost:8000
# Em produção (Railway):
# SITE_URL=https://seusite.up.railway.app
